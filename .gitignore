# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Logs
*.log
nohup.out

# Local environment overrides (so secrets/keys don't leak into the repo)
.env
.env.local
docker-compose.override.yml

# Jekyll build output
_site/
.jekyll-cache/
